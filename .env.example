# Required — Slack Bot and App tokens
# Get these from https://api.slack.com/apps → your app → Basic Information
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Optional — Hack Club AI shared key
# When set, all users get free Hack Club AI access without running /stderr-connect.
# Get yours from https://ai.hackclub.com
HACKCLUB_API_KEY=
